# pnpm Configuration
# https://pnpm.io/npmrc

# Use strict peer dependencies (fail on missing peer deps)
strict-peer-dependencies=true

# Auto-install peer dependencies
auto-install-peers=true

# Use shamefully-hoist for better compatibility (optional, use sparingly)
# shamefully-hoist=false

# Node linker strategy (better for monorepos)
node-linker=isolated

# Store path for pnpm cache (optional)
# store-dir=.pnpm-store

# Resolution mode for faster installs
resolution-mode=highest
